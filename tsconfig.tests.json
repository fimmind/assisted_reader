{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "outDir": ".tmp-tests",
    "rootDir": ".",
    "types": ["node"],
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "isolatedModules": false
  },
  "include": [
    "src/core/constants.ts",
    "src/core/math.ts",
    "src/core/nlp.ts",
    "src/core/types.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "build"]
}
